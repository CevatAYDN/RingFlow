# Unity WebGL builds
✨Builds/

# OS-specific files
.DS_Store
Thumbs.db

# ==========================================
# AI and LLM Exclusion Filters (Strict)
# ==========================================
# Python Virtual Environments
.venv/
venv/
env/
.env/
ENV/
bin/
lib/
share/
pyvenv.cfg
pip-selfcheck.json

# Python cache & logs
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.ipynb_checkpoints/
pip-log.txt

# API Keys, secrets, and environment configurations
.env
.env.*
*.env
secrets*
credentials*
*key*.txt
*key*.json

# Jupyter Notebooks and Python scripts
*.ipynb
*.py
requirements.txt
Pipfile
poetry.lock

