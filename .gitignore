# Devin environment config (allow blueprint and MCP config to be shared)
!/.devin/
/.devin/*
!/.devin/blueprint.yaml
!/.devin/config.json
!/.devin/mcp-client-config.example.json
!/.devin/start-unity-mcp-server.ps1
/AGENTS.md

